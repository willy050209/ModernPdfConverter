<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ModernPdfConverter.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="450"
        x:Class="ModernPdfConverter.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="現代化 PDF 轉換器"
        Width="650" Height="500"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="Auto, Auto, Auto, *, Auto" Margin="20">
        <!-- Header -->
        <TextBlock Grid.Row="0" Text="現代化 PDF 轉換器" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

        <!-- Path Selection -->
        <StackPanel Grid.Row="1" Spacing="10">
            <Grid ColumnDefinitions="*, Auto, Auto, Auto">
                <TextBox Text="{Binding SourcePath}" Watermark="選擇來源檔案或資料夾..." VerticalContentAlignment="Center" IsReadOnly="True"/>
                <Button Grid.Column="1" Content="單檔" Command="{Binding SelectSourceFileCommand}" Margin="5,0,0,0"/>
                <Button Grid.Column="2" Content="多檔" Command="{Binding SelectSourceFilesCommand}" Margin="5,0,0,0"/>
                <Button Grid.Column="3" Content="目錄" Command="{Binding SelectSourceFolderCommand}" Margin="5,0,0,0"/>
            </Grid>

            <Grid ColumnDefinitions="*, Auto">
                <TextBox Text="{Binding DestinationPath}" Watermark="選擇儲存路徑 (PDF 檔案或目錄)..." VerticalContentAlignment="Center"/>
                <Button Grid.Column="1" Content="瀏覽" Command="{Binding SelectDestinationCommand}" Margin="5,0,0,0"/>
            </Grid>
        </StackPanel>

        <!-- Actions -->
        <Button Grid.Row="2" Content="開始轉換" 
                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                Margin="0,20,0,0" Height="40"
                Classes="accent"
                Command="{Binding ConvertCommand}"
                IsEnabled="{Binding !IsProcessing}"/>

        <!-- Log/Progress -->
        <DockPanel Grid.Row="3" Margin="0,20,0,0">
            <ProgressBar DockPanel.Dock="Top" Value="{Binding ProgressValue}" Height="10" Margin="0,0,0,10" IsVisible="{Binding IsProcessing}"/>
            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="1" CornerRadius="4">
                <ListBox ItemsSource="{Binding LogMessages}" 
                         Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                         Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontSize="12" FontFamily="Consolas, Monaco, monospace"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </DockPanel>

        <!-- Status -->
        <TextBlock Grid.Row="4" Text="{Binding StatusText}" Margin="0,10,0,0" Foreground="Gray" FontSize="12"/>
    </Grid>
</Window>
